#!/bin/sh
set -eu

if [ "${SKIP_VERIFY_PUSH:-0}" = "1" ]; then
	exit 0
fi

LOCAL_NODE_HELPER="/Users/pascalwagner/Documents/New project/.dev-tools/use-local-node.sh"

if ! command -v npm >/dev/null 2>&1 && [ -f "$LOCAL_NODE_HELPER" ]; then
	. "$LOCAL_NODE_HELPER"
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT/dealflow"
npm run verify:push
