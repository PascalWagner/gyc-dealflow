{
  "buildCommand": "",
  "installCommand": "",
  "framework": null,
  "functions": {
    "api/deck-upload.js": { "maxDuration": 60 },
    "api/ghl-sync.js": { "maxDuration": 120 }
  },
  "crons": [
    { "path": "/api/ghl-sync", "schedule": "0 * * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=0, must-revalidate" }
      ]
    }
  ]
}
