#!/bin/sh
# Pre-commit hook: run unit tests for staged dealflow changes
# Install: npm run setup-hooks (from dealflow/ directory)

# Only run if JS/TS/Svelte files in dealflow are staged
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^dealflow/.*\.(js|mjs|ts|svelte)$')

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "🧪 Running unit tests..."

# Run from dealflow directory
cd "$(git rev-parse --show-toplevel)/dealflow" || exit 1
npm run test:unit:all --silent

if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Fix failing tests before committing."
  exit 1
fi

echo "✅ Tests passed."

# Enforce: new API endpoints must have a mock in api-mocks.mjs
NEW_API_FILES=$(git diff --cached --name-only --diff-filter=A | grep '^api/' | grep -v '^api/_' | grep -v '^api/admin-manage/' | grep -v '^api/member/deals/' | grep -v '^api/userdata/' | grep -v '^api/v1/' | grep '\.js$')
if [ -n "$NEW_API_FILES" ]; then
  MISSING_MOCKS=""
  for file in $NEW_API_FILES; do
    endpoint=$(basename "$file" .js)
    if ! grep -q "api/${endpoint}" tests/fixtures/api-mocks.mjs 2>/dev/null; then
      MISSING_MOCKS="${MISSING_MOCKS}\n  - ${endpoint} (add: page.route('**/api/${endpoint}**', ...) to tests/fixtures/api-mocks.mjs)"
    fi
  done
  if [ -n "$MISSING_MOCKS" ]; then
    echo ""
    echo "ERROR: New API endpoints missing mock stubs in tests/fixtures/api-mocks.mjs:"
    echo -e "$MISSING_MOCKS"
    echo ""
    echo "Add a minimal mock to installCoreApiMocks() before committing."
    exit 1
  fi
fi

exit 0
