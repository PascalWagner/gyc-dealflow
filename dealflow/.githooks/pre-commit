#!/bin/sh
# Pre-commit hook: run unit tests for staged dealflow changes
# Install: npm run setup-hooks (from dealflow/ directory)

# Only run if JS/TS/Svelte files in dealflow are staged
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^dealflow/.*\.(js|mjs|ts|svelte)$')

if [ -z "$STAGED" ]; then
  exit 0
fi

echo "🧪 Running unit tests..."

# Run from dealflow directory
cd "$(git rev-parse --show-toplevel)/dealflow" || exit 1
npm run test:unit:all --silent

if [ $? -ne 0 ]; then
  echo "❌ Unit tests failed. Fix failing tests before committing."
  exit 1
fi

echo "✅ Tests passed."
exit 0
